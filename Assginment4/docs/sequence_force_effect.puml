@startuml ForceEffect
title Sequence Diagram - Force Effect on Entity
autonumber

participant "update_scene" as Scene
participant GameEntity
participant PhysicsBody
participant CollisionHeap
participant CollisionSystem
participant "Collision Bridge" as Bridge

Scene -> GameEntity : game_entity_begin_frame()
GameEntity -> GameEntity : save prev position\nreset collision accumulators

Scene -> GameEntity : game_entity_apply_force(force)
GameEntity -> PhysicsBody : physics_body_apply_force(force)
PhysicsBody -> PhysicsBody : accumulated_force += force

Scene -> GameEntity : game_entity_integrate_physics(dt)
GameEntity -> PhysicsBody : physics_body_integrate(dt, &dx, &dy, &dz)
PhysicsBody -> PhysicsBody : velocity += force / mass * dt
PhysicsBody -> PhysicsBody : apply damping
PhysicsBody --> GameEntity : dx, dy, dz
GameEntity -> GameEntity : game_entity_move(dx, dy, dz)
GameEntity -> GameEntity : game_entity_sync_parts()

Scene -> CollisionSystem : collision_system_call(heap)
CollisionSystem -> CollisionHeap : iterate colliders
CollisionSystem -> Bridge : notify collision callbacks
Bridge -> GameEntity : game_entity_part_collision_bridge(...)
GameEntity -> GameEntity : accumulate collision normal

Scene -> GameEntity : game_entity_resolve_collisions()
GameEntity -> PhysicsBody : physics_body_remove_normal_component(nx, ny, nz)
GameEntity -> GameEntity : correct penetration using prev position
GameEntity -> GameEntity : game_entity_sync_parts()
@enduml
