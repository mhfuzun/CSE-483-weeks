@startuml Assignment4ClassDiagram
title Assignment 4 Class Diagram
skinparam classAttributeIconSize 0
hide empty members

note "Bu proje C ile yazildi.\nClass kutulari struct + ilgili modulleri temsil eder." as N1

package "Core" {
    enum GamePrimitiveType {
        GAME_PRIMITIVE_CUBE
        GAME_PRIMITIVE_CYLINDER
        GAME_PRIMITIVE_PLANE
        GAME_PRIMITIVE_SPHERE
    }

    class GameObject {
        +name : const char*
        +primitive_type : GamePrimitiveType
        +local_x, local_y, local_z : float
        +local_rot_x, local_rot_y, local_rot_z : float
        +world_x, world_y, world_z : float
        +size_x, size_y, size_z : float
        +radius : float
        +color_r, color_g, color_b : float
        +visible : bool
        +collider : Collision*
        +owner_object : void*
        +game_object_create(name, primitive_type)
        +game_object_attach_collider(...)
        +game_object_sync_world(owner_x, owner_y, owner_z)
        +game_object_draw()
    }

    class GameEntity {
        +name : const char*
        +x, y, z : float
        +prev_x, prev_y, prev_z : float
        +parts : GameObject**
        +part_count : size_t
        +part_capacity : size_t
        +physics : PhysicsBody
        +physics_enabled : int
        +collision_count : int
        +accumulated_normal_x : float
        +accumulated_normal_y : float
        +accumulated_normal_z : float
        +is_colliding : int
        +on_collision : GameEntityCollisionFn
        +game_entity_create(name, initial_part_capacity)
        +game_entity_add_primitive(part_name, primitive_type)
        +game_entity_attach_part_collider(...)
        +game_entity_enable_physics(mass, damping)
        +game_entity_apply_force(force)
        +game_entity_integrate_physics(dt)
        +game_entity_resolve_collisions()
        +game_entity_draw()
    }
}

package "Physics" {
    class PhysicsBody {
        +enabled : bool
        +mass : float
        +damping : float
        +velocity_x, velocity_y, velocity_z : float
        +accumulated_force_x : float
        +accumulated_force_y : float
        +accumulated_force_z : float
        +physics_body_init(mass, damping)
        +physics_body_apply_force(force)
        +physics_body_integrate(dt, dx, dy, dz)
        +physics_body_remove_normal_component(nx, ny, nz)
    }

    class Force {
        +x, y, z : float
        +duration : float
        +force_create(x, y, z, duration)
    }
}

package "Collision" {
    enum CollisionClass {
        COLLISION_CLASS_STATIC
        COLLISION_CLASS_DYNAMIC
    }

    enum CollisionShape {
        COLLISION_SHAPE_AABB
        COLLISION_SHAPE_CUBE
        COLLISION_SHAPE_SPHERE
    }

    class CollisionVec3 {
        +x : float
        +y : float
        +z : float
    }

    class Collision {
        +owner : void*
        +class_type : CollisionClass
        +shape_type : CollisionShape
        +center : CollisionVec3
        +half_extents : CollisionVec3
        +radius : float
        +enabled : bool
        +on_collision : CollisionCallback
        +collision_create(owner, class_type, shape_type)
        +collision_set_position(x, y, z)
        +collision_set_half_extents(hx, hy, hz)
        +collision_set_radius(radius)
        +collision_set_callback(callback)
    }

    class CollisionHeap {
        +items : Collision**
        +size : size_t
        +capacity : size_t
        +collision_heap_create(initial_capacity)
        +collision_heap_push(collider)
        +collision_heap_remove(collider)
        +collision_system_call()
    }
}

package "Factories" {
    class PlayerFactory {
        +player_create(heap, x, y, z, on_collision)
    }

    class TreeFactory {
        +tree_create(heap, x, y, z, on_collision)
    }

    class HouseFactory {
        +house_create(heap, x, y, z, on_collision)
    }
}

N1 .. GameEntity
GameEntity "1" *-- "0..*" GameObject : parts
GameEntity *-- PhysicsBody : physics
GameEntity ..> Force : applies
GameEntity ..> CollisionHeap : uses

GameObject --> GamePrimitiveType
GameObject "0..1" --> Collision : collider
GameObject ..> CollisionHeap : attach / detach

Collision --> CollisionClass
Collision --> CollisionShape
Collision --> CollisionVec3 : center
Collision --> CollisionVec3 : half_extents
CollisionHeap "1" o-- "0..*" Collision : items

PlayerFactory ..> GameEntity : creates
TreeFactory ..> GameEntity : creates
HouseFactory ..> GameEntity : creates
@enduml
