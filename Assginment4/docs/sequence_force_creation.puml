@startuml ForceCreation
title Sequence Diagram - Force Creation
autonumber

actor PlayerInput
participant "update_input_forces" as InputSystem
participant Force

PlayerInput -> InputSystem : direction key pressed\n(dt known)
InputSystem -> InputSystem : compute facing vector (g_lx, g_lz)

alt forward pressed
    InputSystem -> Force : force_create(g_lx * move_force,\n0,\ng_lz * move_force,\ndt)
    create Force
    Force --> InputSystem : Force value
else back pressed
    InputSystem -> Force : force_create(-g_lx * move_force,\n0,\n-g_lz * move_force,\ndt)
    create Force
    Force --> InputSystem : Force value
end

InputSystem --> PlayerInput : ready-to-apply Force
@enduml
